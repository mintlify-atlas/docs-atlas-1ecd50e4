  "keyFeatures": [
    "JWT authentication with OTP email verification",
    "Role-based access control for buyers, farmers, and transporters",
    "Produce catalog management with filtering, search, and availability tracking",
    "Order management with status lifecycle (Pending → Paid → In Transit → Completed)",
    "Squad payment gateway integration with escrow, payment splits, and payouts",
    "Virtual accounts for farmers and transporters",
    "Recurring subscriptions (daily/weekly/monthly) with pause, resume, and cancel",
    "Delivery tracking with rider earnings management",
    "OpenAPI schema available via drf-spectacular"
  ],
  "publicApiSurface": [
